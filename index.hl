<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Slides</title>

<style>
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
    background: #ffffff;
    color: #111;
  }

  header {
    padding: 16px;
    font-size: 18px;
    font-weight: 600;
    border-bottom: 1px solid #eee;
  }

  .container {
    padding: 14px;
    max-width: 900px;
    margin: auto;
  }

  .actions {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .btn {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
    font-size: 14px;
  }

  .btn:hover {
    background: #f7f7f7;
  }

  #status {
    font-size: 13px;
    color: #666;
    margin-bottom: 10px;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  .card {
    border: 1px solid #eee;
    border-radius: 10px;
    padding: 8px;
    background: #fff;
  }

  .card img {
    width: 100%;
    border-radius: 6px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }

  .small-btn {
    margin-top: 6px;
    padding: 6px;
    font-size: 12px;
    border-radius: 6px;
    border: 1px solid #ddd;
    background: #fafafa;
    cursor: pointer;
    width: 100%;
  }

  .small-btn:hover {
    background: #f0f0f0;
  }

</style>
</head>

<body>

<header>Slides</header>

<div class="container">

  <div class="actions">
    <button class="btn" onclick="downloadSelected()">Download Selected</button>
    <button class="btn" onclick="downloadAll()">Download All</button>
  </div>

  <div id="status">Loading slides...</div>

  <div id="gallery" class="gallery"></div>

</div>

<script>

const API_URL = "https://script.google.com/macros/s/AKfycbwJzrL8XNgVkxgCf9qgBnxbBAxeqNsolutRGoyoQkvtDdVKY_tsmJde6ll4D5Ci6zEyCA/exec?action=getSlides";
// 🔁 GANTI URL

let images = [];

window.onload = loadSlides; // ✅ AUTO LOAD

function loadSlides() {
  fetch(API_URL)
    .then(res => res.json())
    .then(res => {
      images = res;
      renderGallery();
      document.getElementById("status").innerText = images.length + " slides loaded";
    })
    .catch(err => {
      console.error(err);
      document.getElementById("status").innerText = "Failed to load ❌";
    });
}

function renderGallery() {
  let gallery = document.getElementById("gallery");
  gallery.innerHTML = "";

  images.forEach((img, i) => {
    let div = document.createElement("div");
    div.className = "card";

    div.innerHTML = `
      <div class="card-top">
        <input type="checkbox" checked id="chk_${i}">
        <span style="font-size:12px;color:#888">${img.name}</span>
      </div>

      <img src="data:image/png;base64,${img.data}">

      <button class="small-btn" onclick="downloadOne(${i})">
        Download
      </button>
    `;

    gallery.appendChild(div);
  });
}

function downloadOne(i) {
  download(images[i]);
}

function downloadSelected() {
  let selected = images.filter((img, i) =>
    document.getElementById("chk_" + i).checked
  );

  if (selected.length === 0) {
    alert("No slide selected");
    return;
  }

  processDownload(selected);
}

function downloadAll() {
  if (images.length === 0) return;
  processDownload(images);
}

function processDownload(list) {
  document.getElementById("status").innerText = "Downloading...";

  list.forEach((img, index) => {
    setTimeout(() => {
      download(img);
    }, index * 250);
  });

  setTimeout(() => {
    document.getElementById("status").innerText = "Done";
  }, list.length * 250);
}

function download(img) {
  let link = document.createElement("a");
  link.href = "data:image/png;base64," + img.data;
  link.download = img.name;
  link.click();
}

</script>

</body>
</html>
